# promptward gateway configuration. Copy to .env; everything here is optional --
# the gateway boots with no setup (in-memory store, no provider keys required).

# Gateway
PORT=8787

# Providers (needed only to actually proxy a call, not to boot)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Event store: set DATABASE_URL to use Postgres; unset uses the in-memory store.
# DATABASE_URL=postgres://promptward:promptward@localhost:5432/promptward

# Detection policy (defaults match the eval)
PROMPTWARD_THRESHOLD=0.5
PROMPTWARD_MAX_RETRIES=2

# Max bytes of scannable text per request; larger requests are rejected (413)
# so a pathological input cannot block the scan loop. The raw body is capped at
# 8x this before parsing.
PROMPTWARD_MAX_SCAN_BYTES=1000000
