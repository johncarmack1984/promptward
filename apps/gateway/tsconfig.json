{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Node service: NodeNext module semantics override the base's bundler set.
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"]
}
